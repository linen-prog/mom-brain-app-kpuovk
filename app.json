{
  "expo": {
    "name": "Mom Brain",
    "slug": "mom-brain",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ChatGPT Image Jul 1, 2026, 02_52_50 PM.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/ChatGPT Image Jul 1, 2026, 02_52_50 PM.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hersomatic.mombrain",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ChatGPT Image Jul 1, 2026, 02_52_50 PM.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.placeholder.app"
    },
    "web": {
      "favicon": "./assets/images/newly.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": "Mom Brain uses your microphone so you can talk it out instead of typing."
        }
      ],
      "@bacons/apple-targets"
    ],
    "scheme": "mombrain",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://dquu5k3ghhrbb3rjpvqbshwn8u7w2tkw.app.specular.dev"
    }
  }
}